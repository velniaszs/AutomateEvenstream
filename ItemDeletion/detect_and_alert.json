                                    "value": "@concat('.set-or-append AlertLogs <| \nlet targetWorkspaceId = toguid(\"', item().WorkspaceId,'\");\nlet targetItemIdsString = \"', item().ItemIds,'\";\nlet targetItemIds = split(replace_string(targetItemIdsString, \" \", \"\"), \",\");\nAlertLogs\n| extend IngestionTime = ingestion_time()\n| summarize arg_max(IngestionTime, *) by WorkspaceId, data_itemId\n| where WorkspaceId == targetWorkspaceId and data_itemId in (targetItemIds)\n| project WorkspaceName, WorkspaceId, wstime, data_itemKind, data_itemName, data_itemId, AlertStatus = \"EmailSent\"\n')",
                                    "type": "Expression"
