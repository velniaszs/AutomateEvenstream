                    "retry": 0,
                    "retryIntervalInSeconds": 30,
                    "secureOutput": false,
                    "secureInput": false
                },
                "typeProperties": {
                    "command": {
                        "value": "@concat('.append AlertLogs <| \nlet lastRunParam = toscalar(MonitoringLastRunTime | summarize max(LastRunTime));\nlet startTimeFilter = case(isnull(lastRunParam), ago(100d), lastRunParam > ago(1h), ago(1h), lastRunParam);\nlet ak = AllowedAOPItemKind;\nlet wl = WorkspaceLogs\n| where ingestion_time() > startTimeFilter\n| where ingestion_time() < todatetime(\"', variables('now'),'\")\n| extend IngestionTime = ingestion_time()\n| where type == \"Microsoft.Fabric.ItemCreateSucceeded\"\n| project WorkspaceName = data_workspaceName, data_workspaceId, wstime = [\"time\"], data_itemName, data_itemId, data_itemKind, type, IngestionTime;\nlet aop =\nWorkspaceOutboundAccessProtection\n| summarize arg_max(CreationTime, Activity) by WorkspaceId\n| where Activity == \"DisableWorkspaceOutboundAccessProtection\"\n| project WorkspaceId;\nlet daop =\nDataverseAOP\n| where Activity == \"EnableWorkspaceOutboundAccessProtection\"\n| project WorkspaceId;\nwl\n| join kind = inner \n    aop\n    on  $left.data_workspaceId == $right.WorkspaceId\n| join kind = inner \n    daop\n    on  $left.data_workspaceId == $right.WorkspaceId\n| join kind = leftanti \n    ak\n    on $left.data_itemKind == $right.ItemKind\n| project WorkspaceName, WorkspaceId, wstime, data_itemKind, data_itemName, data_itemId\n| extend AlertStatus = \"Initial\"\n// 3. Filter out records that already exist in the destination table\n| join kind=leftanti (\n    AlertLogs \n) on WorkspaceId, data_itemId')",
                        "type": "Expression"
                    },
                    "commandTimeout": "00:20:00"
                },
                "linkedService": {
                    "name": "MonitoringEventhouse",
                    "objectId": "9dfa4f65-3226-4324-b450-5cdf8cdb11a4",
